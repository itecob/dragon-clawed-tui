# Copy to .env for local development. Do not commit real provider keys.
# Dragon Clawed TUI supports any OpenAI-compatible chat completions backend.
OPENAI_BASE_URL=http://127.0.0.1:8000/v1
OPENAI_API_KEY=local-token
OPENAI_MODEL=your-model-id

# Optional delegated/helper backend. Leave unset to use the main backend.
# CLAWED_HELPER_BASE_URL=http://127.0.0.1:8001/v1
# CLAWED_HELPER_MODEL_ID=your-helper-model-id

# Optional local llama-server startup. Leave unset if you already run a backend.
# CLAWED_LLAMA_SERVER_BIN=/path/to/llama-server
# CLAWED_MAIN_MODEL=/path/to/model.gguf
# CLAWED_MAIN_MODEL_ID=your-model-id
# CLAWED_HELPER_MODEL=/path/to/helper-model.gguf
# CLAWED_HELPER_MODEL_ID=your-helper-model-id
# CLAWED_CONTEXT_SIZE=8192
# CLAWED_CACHE_TYPE_K=q8_0
# CLAWED_CACHE_TYPE_V=q8_0

# Optional TUI settings
CLAWED_TUI_THEME=codex
CLAWED_MODEL_TIMEOUT_SECONDS=300
